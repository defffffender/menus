# Пример конфигурации окружения. Скопируйте в .env и заполните.
# .env в git НЕ коммитится (секреты!).

# --- База ---
# На проде ОБЯЗАТЕЛЬНО DEBUG=False
DEBUG=True
# Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=change-me
# На проде перечислить домены через запятую: menu.example.uz,www.menu.example.uz
ALLOWED_HOSTS=
# На проде (через запятую): https://menu.example.uz,https://www.menu.example.uz
CSRF_TRUSTED_ORIGINS=

# --- База данных ---
# По умолчанию SQLite. Для PostgreSQL раскомментируйте (нужен psycopg из requirements):
# DATABASE_URL=postgres://menus:ПАРОЛЬ@127.0.0.1:5432/menus

# --- Realtime ---
# Channel layer для WebSocket на проде. Dev можно пусто (InMemory, один процесс).
# REDIS_URL=redis://127.0.0.1:6379/0

# --- Безопасность (учитывается только при DEBUG=False) ---
# Если разворачиваете по IP без HTTPS — поставьте False, иначе будет редирект-петля.
SECURE_SSL_REDIRECT=True
# Срок HSTS в секундах (по умолчанию 30 дней). После проверки можно поднять до года.
# SECURE_HSTS_SECONDS=2592000

# --- SMS (Eskiz.uz) ---
# False — код подтверждения пишется в лог/консоль (dev). True — реальная отправка.
ESKIZ_ENABLED=False
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# '4546' — тестовый отправитель; брендовый ник регистрируется в кабинете Eskiz.
ESKIZ_FROM=4546
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

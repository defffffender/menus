# Пример конфигурации окружения. Скопируйте в .env и заполните.
# .env в git НЕ коммитится (секреты!).

# --- База ---
DEBUG=True
# Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=change-me
# На проде перечислить домены через запятую: menu.example.uz,www.menu.example.uz
ALLOWED_HOSTS=
# На проде: https://menu.example.uz
CSRF_TRUSTED_ORIGINS=
# Channel layer для realtime на проде (dev можно пусто — InMemory):
REDIS_URL=

# --- SMS (Eskiz.uz) ---
# False — код подтверждения пишется в лог/консоль (dev). True — реальная отправка.
ESKIZ_ENABLED=False
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# '4546' — тестовый отправитель; брендовый ник регистрируется в кабинете Eskiz.
ESKIZ_FROM=4546
ESKIZ_BASE_URL=https://notify.eskiz.uz/api
